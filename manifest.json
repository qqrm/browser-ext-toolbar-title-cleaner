{
  "manifest_version": 2,
  "name": "Toolbar Title Cleaner",
  "version": "0.2.2",
  "description": "Clears titles only for newly created direct Bookmarks Toolbar bookmarks (not inside folders).",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  },
  "permissions": [
    "bookmarks"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "applications": {
    "gecko": {
      "id": "toolbar-title-cleaner@local"
    }
  }
}
